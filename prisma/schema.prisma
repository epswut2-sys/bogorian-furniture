// Generated by Skylia AI Builder — Bogorian Furniture
// DO NOT EDIT MANUALLY — regenerate via the Skylia dashboard

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


// Marketplace participants — registered sellers (craftsmen/stores); buyers may be guests
model User {
  id         String   @id @default(cuid())
  clerkId  String @unique
  email  String @unique
  name  String?
  avatarUrl  String?
  isSeller  Boolean @default(false)
  storeName  String?
  phoneNumber  String?
  city  String?
  province  String?
  sellerOnboarded  Boolean @default(false)
  stripeAccountId  String? @unique
  stripeCustomerId  String? @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  subscriptionId  String?
  subscriptionStatus  String?
  currentPeriodEnd  DateTime?
  listings  Listing[]
  orders  Order[]
  reviews  Review[]
}

// Product categories for filtering and navigation (Wall Shelves, Home Decor, Storage)
model Category {
  id         String   @id @default(cuid())
  name  String @unique
  slug  String @unique
  description  String?
  imageUrl  String?
  sortOrder  Int @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  listings  Listing[]
}

// Furniture products listed by sellers with IDR pricing and stock management
model Listing {
  id         String   @id @default(cuid())
  sellerId  String
  categoryId  String?
  title  String
  description  String?
  priceIdr  Int
  imageUrls  Json?
  material  String?
  dimensions  String?
  weightKg  Float?
  stockCount  Int @default(0)
  status  String @default("draft")
  isFeatured  Boolean @default(false)
  viewCount  Int @default(0)
  publishedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user  User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orders  Order[]
  reviews  Review[]
}

// Purchase transactions including guest buyer details and Indonesian shipping address
model Order {
  id         String   @id @default(cuid())
  sellerId  String
  listingId  String
  buyerName  String
  buyerEmail  String?
  buyerPhone  String
  shippingAddress  String
  city  String
  province  String
  quantity  Int @default(1)
  totalPriceIdr  Int
  platformFeeIdr  Int
  sellerPayoutIdr  Int
  status  String @default("pending")
  stripePaymentIntentId  String? @unique
  notes  String?
  completedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user  User @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviews  Review[]
}

// Buyer reviews submitted after order completion to build seller trust
model Review {
  id         String   @id @default(cuid())
  orderId  String @unique
  listingId  String
  authorId  String
  rating  Int
  body  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  listing  Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user  User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}
